{
  "info": {
    "name": "Form Management API",
    "description": "Collection cho toàn bộ endpoint của Form Management API. Chạy 'Login' trước, access_token/refresh_token sẽ tự lưu vào collection variables cho các request khác dùng.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "form_id", "value": "" },
    { "key": "field_id", "value": "" },
    { "key": "user_id", "value": "" },
    { "key": "role_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.access_token) {",
                  "  pm.collectionVariables.set('access_token', body.access_token);",
                  "  pm.collectionVariables.set('refresh_token', body.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Refresh token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.access_token) { pm.collectionVariables.set('access_token', body.access_token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}" },
            "url": { "raw": "{{base_url}}/api/auth/refresh", "host": ["{{base_url}}"], "path": ["api", "auth", "refresh"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/auth/logout", "host": ["{{base_url}}"], "path": ["api", "auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "Forms",
      "item": [
        {
          "name": "List forms (paginated)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/forms?page=1&per_page=20",
              "host": ["{{base_url}}"],
              "path": ["api", "forms"],
              "query": [{ "key": "page", "value": "1" }, { "key": "per_page", "value": "20" }]
            }
          }
        },
        {
          "name": "Create form",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.id) { pm.collectionVariables.set('form_id', body.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Employee Onboarding\",\n  \"description\": \"Basic onboarding info form\",\n  \"order\": 1,\n  \"status\": \"active\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/forms", "host": ["{{base_url}}"], "path": ["api", "forms"] }
          }
        },
        {
          "name": "Get form detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/forms/{{form_id}}", "host": ["{{base_url}}"], "path": ["api", "forms", "{{form_id}}"] }
          }
        },
        {
          "name": "Update form",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"active\"\n}" },
            "url": { "raw": "{{base_url}}/api/forms/{{form_id}}", "host": ["{{base_url}}"], "path": ["api", "forms", "{{form_id}}"] }
          }
        },
        {
          "name": "Delete form",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/forms/{{form_id}}", "host": ["{{base_url}}"], "path": ["api", "forms", "{{form_id}}"] }
          }
        },
        {
          "name": "List active forms",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/forms/active", "host": ["{{base_url}}"], "path": ["api", "forms", "active"] }
          }
        }
      ]
    },
    {
      "name": "Fields",
      "item": [
        {
          "name": "Create field",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.id) { pm.collectionVariables.set('field_id', body.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"label\": \"Full name\",\n  \"type\": \"text\",\n  \"order\": 1,\n  \"required\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/forms/{{form_id}}/fields",
              "host": ["{{base_url}}"],
              "path": ["api", "forms", "{{form_id}}", "fields"]
            }
          }
        },
        {
          "name": "Update field",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"label\": \"Full legal name\"\n}" },
            "url": {
              "raw": "{{base_url}}/api/forms/{{form_id}}/fields/{{field_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "forms", "{{form_id}}", "fields", "{{field_id}}"]
            }
          }
        },
        {
          "name": "Delete field",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/forms/{{form_id}}/fields/{{field_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "forms", "{{form_id}}", "fields", "{{field_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Submissions",
      "item": [
        {
          "name": "Submit form",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"answers\": {\n    \"<field_id>\": \"value\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/forms/{{form_id}}/submit",
              "host": ["{{base_url}}"],
              "path": ["api", "forms", "{{form_id}}", "submit"]
            }
          }
        },
        {
          "name": "List submissions (paginated)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/submissions?page=1&per_page=20",
              "host": ["{{base_url}}"],
              "path": ["api", "submissions"],
              "query": [{ "key": "page", "value": "1" }, { "key": "per_page", "value": "20" }]
            }
          }
        }
      ]
    },
    {
      "name": "Users (admin)",
      "item": [
        {
          "name": "List users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/users", "host": ["{{base_url}}"], "path": ["api", "users"] }
          }
        },
        {
          "name": "Create user",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.id) { pm.collectionVariables.set('user_id', body.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"new.employee@example.com\",\n  \"password\": \"Employee@123\",\n  \"full_name\": \"New Employee\",\n  \"role_names\": [\"employee\"]\n}"
            },
            "url": { "raw": "{{base_url}}/api/users", "host": ["{{base_url}}"], "path": ["api", "users"] }
          }
        },
        {
          "name": "Update user",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"full_name\": \"Updated Name\"\n}" },
            "url": { "raw": "{{base_url}}/api/users/{{user_id}}", "host": ["{{base_url}}"], "path": ["api", "users", "{{user_id}}"] }
          }
        },
        {
          "name": "Delete user",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/users/{{user_id}}", "host": ["{{base_url}}"], "path": ["api", "users", "{{user_id}}"] }
          }
        }
      ]
    },
    {
      "name": "Roles (admin)",
      "item": [
        {
          "name": "List roles",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/roles", "host": ["{{base_url}}"], "path": ["api", "roles"] }
          }
        },
        {
          "name": "Create role",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.id) { pm.collectionVariables.set('role_id', body.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"viewer\",\n  \"description\": \"Read-only role\"\n}" },
            "url": { "raw": "{{base_url}}/api/roles", "host": ["{{base_url}}"], "path": ["api", "roles"] }
          }
        },
        {
          "name": "Update role",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"description\": \"Updated description\"\n}" },
            "url": { "raw": "{{base_url}}/api/roles/{{role_id}}", "host": ["{{base_url}}"], "path": ["api", "roles", "{{role_id}}"] }
          }
        },
        {
          "name": "Delete role",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/roles/{{role_id}}", "host": ["{{base_url}}"], "path": ["api", "roles", "{{role_id}}"] }
          }
        },
        {
          "name": "Set role permissions",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"permission_codes\": [\"forms:view_active\", \"submissions:create\", \"submissions:view_own\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/roles/{{role_id}}/permissions",
              "host": ["{{base_url}}"],
              "path": ["api", "roles", "{{role_id}}", "permissions"]
            }
          }
        }
      ]
    },
    {
      "name": "Permissions (admin, read-only)",
      "item": [
        {
          "name": "List permissions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/permissions", "host": ["{{base_url}}"], "path": ["api", "permissions"] }
          }
        }
      ]
    }
  ]
}
